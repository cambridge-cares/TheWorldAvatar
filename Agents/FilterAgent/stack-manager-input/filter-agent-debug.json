{
  "ServiceSpec": {
    "Name": "filter-agent",
    "TaskTemplate": {
      "ContainerSpec": {
        "Image": "ghcr.io/cambridge-cares/filter-agent:1.0.1-SNAPSHOT",
        "Mounts": [
          {
            "Type": "bind",
            "Source": "../data/filter-queries",
            "Target": "/inputs/queries"
          }
        ],
        "Env": [
          "JAVA_TOOL_OPTIONS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=*:5005",
          "DEFAULT_NAMESPACE=kb",
          "DEFAULT_QUERY=query"
        ],
        "Configs": [
          {
            "ConfigName": "blazegraph"
          },
          {
            "ConfigName": "ontop"
          }
        ]
      }
    },
    "EndpointSpec": {
      "Ports": [
        {
          "Name": "web",
          "Protocol": "tcp",
          "TargetPort": "5005",
          "PublishedPort": "5005"
        }
      ]
    }
  },
  "endpoints": {
    "filter-agent": {
      "url": "http://localhost:8080/",
      "externalPath": "/filter-agent/"
    }
  }
}